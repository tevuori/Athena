# ===== Athena Student OS — environment variables =====
# Copy to .env and fill in. The real .env is gitignored.

# --- Server ---
SERVER_PORT=3001
SERVER_HOST=0.0.0.0
DATABASE_URL="file:./data/athena.db"
# IMPORTANT: set a long random string (>= 32 chars) for any non-local deploy.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
# Default seed admin (created on first run if no users exist).
# IMPORTANT: change SEED_PASSWORD to a strong, unique value before going public,
# then change it again from Settings → Account after first login.
SEED_USERNAME=admin
SEED_PASSWORD=admin
# Comma-separated list of allowed CORS origins for the public deploy.
# When set, only these origins may call the API. Leave empty for local dev
# (reflects the request origin). For the VPS deploy:
#   CLIENT_ORIGIN=https://athena.tevuori.eu
CLIENT_ORIGIN=

# --- Client (Vite) ---
VITE_API_URL=http://localhost:3001

# --- Spotify ---
# Server-wide fallback: used when a user has no per-user Spotify credentials.
# Each user can configure their own Spotify credentials in Settings → Integrations.
# Get these from https://developer.spotify.com/dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# A long-lived refresh token (obtained once via the auth code PKCE flow).
SPOTIFY_REFRESH_TOKEN=
# Redirect URI registered in your Spotify app (must match).
SPOTIFY_REDIRECT_URI=http://localhost:5173/auth/spotify/callback

# --- LRCLIB ---
# Already public API; no key needed. We set a descriptive User-Agent server-side.

# --- LLM (AI Study Assistant — deferred, placeholder) ---
# LLM_PROVIDER=ollama|openai|anthropic
# LLM_API_KEY=
# LLM_BASE_URL=http://localhost:11434

# --- Athena assistant (multi-llm-ts) ---
# Server-wide fallback used when a user has no per-user AI config in the DB.
# Per-user config (apiKey + provider + baseUrl + modelId) is stored encrypted
# in the DB (Settings → Athena Assistant) and takes priority. Any multi-llm-ts
# provider id works: openai | deepseek | anthropic | openrouter | ollama | groq
# | mistralai | google | xai | meta | cerebras.
# If neither per-user nor server-wide keys are set, Athena AI is unavailable.
# OPENAI_PROVIDER=openai
# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# OPENAI_MODEL=
# Whisper model for Voice Notes transcription (OpenAI-compatible /audio/transcriptions).
# Reuses OPENAI_API_KEY / OPENAI_BASE_URL (or per-user AiCredential).
# OPENAI_TRANSCRIPTION_MODEL=whisper-1

# --- ElevenLabs TTS (Interactive Teacher voice) ---
# Server-wide fallback: used when a user has no per-user TtsCredential.
# Each user can configure their own ElevenLabs key in Settings → Athena Assistant.
# Without a key, the Teach Me mode falls back to the browser Web Speech API.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel (default)

# --- Microsoft (Calendar sync) ---
# Server-wide fallback: used when a user has no per-user Microsoft credentials.
# Each user can configure their own MS credentials in Settings → Integrations.
# Azure AD app — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Requires Calendar.ReadWrite + offline_access scopes. The refresh token is
# obtained once via the OAuth2 auth-code flow; Microsoft may rotate it on
# refresh — the server persists the latest token in the DB automatically.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REFRESH_TOKEN=

# --- Athena code execution sandbox (run_code tool) ---
# The sandbox runs Python/JS/TS snippets in a throwaway Docker container.
# Requires the `docker` CLI on the host (or the Docker socket mounted into
# the server container — see docker-compose.yml). Auto-disabled when docker
# is not found. Set to "false" to explicitly disable.
# SANDBOX_ENABLED=true
# SANDBOX_TIMEOUT_MS=10000
# SANDBOX_MAX_CODE_CHARS=20000
# SANDBOX_PYTHON_IMAGE=python:3.12-slim
# SANDBOX_NODE_IMAGE=node:22-slim
# Docker runtime for sandbox containers. Use "runsc" (gVisor) on public
# deployments for kernel-level isolation — prevents container escape.
# Install gVisor first: https://gvisor.dev/docs/user_guide/install/
# SANDBOX_DOCKER_RUNTIME=runsc

# --- Athena web tools ---
# Web search uses DuckDuckGo HTML scraping — no API key required.
# URL fetching (fetch_url, create_notes_from_url) uses @postlight/parser
# for Readability extraction — no API key required.

# --- Ntfy (push notifications + bidirectional Athena channel) ---
# Server-wide fallback used when a user has no per-user Ntfy config in the DB.
# Per-user config (server URL + token + topics) is stored encrypted in the DB
# (Settings → Integrations or the Ntfy app) and takes priority.
# NTFY_SERVER_URL=https://ntfy.sh
# NTFY_TOKEN=
# NTFY_DEFAULT_PRIORITY=3

