# ===== Athena Student OS — environment variables =====
# Copy to .env and fill in. The real .env is gitignored.

# --- Server ---
SERVER_PORT=3001
SERVER_HOST=0.0.0.0
DATABASE_URL="file:./data/athena.db"
JWT_SECRET=change-me-to-a-long-random-string
# Default seed admin (created on first run if no users exist)
SEED_USERNAME=admin
SEED_PASSWORD=admin

# --- Client (Vite) ---
VITE_API_URL=http://localhost:3001

# --- Spotify ---
# Server-side: used to exchange/refresh access tokens for the Web Playback SDK.
# Get these from https://developer.spotify.com/dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# A long-lived refresh token (obtained once via the auth code PKCE flow).
SPOTIFY_REFRESH_TOKEN=
# Redirect URI registered in your Spotify app (must match).
SPOTIFY_REDIRECT_URI=http://localhost:5173/auth/spotify/callback

# --- LRCLIB ---
# Already public API; no key needed. We set a descriptive User-Agent server-side.

# --- LLM (AI Study Assistant — deferred, placeholder) ---
# LLM_PROVIDER=ollama|openai|anthropic
# LLM_API_KEY=
# LLM_BASE_URL=http://localhost:11434

# --- Athena assistant (multi-llm-ts) ---
# Server-wide fallback used when a user has no per-user AI config in the DB.
# Per-user config (apiKey + provider + baseUrl + modelId) is stored encrypted
# in the DB (Settings → AI) and takes priority. Any multi-llm-ts provider id
# works: openai | deepseek | anthropic | openrouter | ollama | groq | mistralai
# | google | xai | meta | cerebras.
# OPENAI_PROVIDER=openai
# OPENAI_BASE_URL=https://opencode.ai/zen/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=deepseek-v4-flash-free

# --- Microsoft (Calendar sync) ---
# Azure AD app — https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Requires Calendar.ReadWrite scope. The refresh token is obtained once via
# the OAuth2 auth-code flow; Microsoft may rotate it on refresh — the server
# persists the latest token in the DB (Setting table) automatically.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REFRESH_TOKEN=

