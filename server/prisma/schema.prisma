generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String   @default("")
  avatarColor  String   @default("#6366f1")
  role         String   @default("USER") // "USER" | "ADMIN"
  athenaInstructions String @default("") // custom instructions injected into Athena system prompt
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notes       Note[]
  noteFolders NoteFolder[]
  tasks       Task[]
  files       VFile[]
  folders     VFolder[]
  settings    Setting[]
  lyricsCache LyricsCache[]
  flashcardDecks FlashcardDeck[]
  courses     Course[]
  vutCreds    VutCredentials?
  aiCred      AiCredential?
  workspaces  Workspace[]
  studySessions StudySession[]
  calendarEvents CalendarEvent[]
  habits      Habit[]
  chatConversations ChatConversation[]
}

model ChatConversation {
  id        String   @id @default(cuid())
  title     String   @default("New Chat")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String   @default("active") // "active" | "archived"
  messages  Json     @default("[]") // array of { role, content, tools?, timestamp }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastMessageAt DateTime @default(now())

  @@index([userId, status])
  @@index([userId, updatedAt])
}

model NoteFolder {
  id       String @id @default(cuid())
  name     String
  parentId String?
  parent   NoteFolder? @relation("NoteFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children NoteFolder[] @relation("NoteFolderTree")
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes    Note[]
  position Int    @default(0)

  @@index([userId, parentId])
}

model Note {
  id        String   @id @default(cuid())
  title     String   @default("Untitled")
  content   String   @default("")
  tags      String   @default("") // comma-separated
  folderId  String?
  folder    NoteFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, folderId])
  @@index([userId, updatedAt])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String       @default("")
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  recurring   String       @default("") // e.g. "daily", "weekly"
  order       Int          @default(0)
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, status])
}

model VFolder {
  id       String   @id @default(cuid())
  name     String
  parentId String?
  parent   VFolder? @relation("VFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children VFolder[] @relation("VFolderTree")
  files    VFile[]   @relation("VFolderFiles")
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, parentId])
}

model VFile {
  id         String   @id @default(cuid())
  name       String
  mimeType   String   @default("application/octet-stream")
  size       Int      @default(0)
  storageKey String   // relative path under uploads/
  folderId   String?
  folder     VFolder? @relation("VFolderFiles", fields: [folderId], references: [id], onDelete: SetNull)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  starred    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastOpenedAt DateTime?

  @@index([userId, folderId])
  @@index([userId, starred])
  @@index([userId, lastOpenedAt])
}

model LyricsCache {
  id            String   @id @default(cuid())
  trackId       String   // Spotify track URI or id
  trackName     String
  artistName    String
  albumName     String   @default("")
  duration      Int      @default(0)
  syncedLyrics  String   @default("") // LRC text
  plainLyrics   String   @default("")
  instrumental  Boolean  @default(false)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fetchedAt     DateTime @default(now())

  @@unique([trackId])
  @@index([trackName, artistName])
}

model Setting {
  id     String @id @default(cuid())
  key    String
  value  String
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ===== Flashcards (Spaced Repetition / SM-2) =====

model FlashcardDeck {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  color       String   @default("#6366f1")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards       Flashcard[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Flashcard {
  id          String   @id @default(cuid())
  deckId      String
  deck        FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  front       String
  back        String
  // SM-2 algorithm fields
  easeFactor  Float    @default(2.5)
  interval    Int      @default(0)  // days
  repetitions Int      @default(0)
  dueDate     DateTime @default(now())
  lastReviewed DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([deckId])
  @@index([dueDate])
}

// ===== Grade Tracker / GPA Calculator =====

model Course {
  id          String   @id @default(cuid())
  name        String
  code        String   @default("")  // e.g. "CS 101"
  semester    String   @default("")  // e.g. "Fall 2025"
  credits     Int      @default(3)
  color       String   @default("#6366f1")
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, semester])
}

model Assignment {
  id         String  @id @default(cuid())
  courseId   String
  course     Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  name       String
  score      Float   // e.g. 92.5
  maxScore   Float   @default(100)
  weight     Float   @default(1) // multiplier for weighted average
  category   String  @default("General") // e.g. "Homework", "Exam", "Quiz"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([courseId])
}

// ===== VUT Integration =====

model VutCredentials {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  username  String  // VUT login (e.g. xlogin00)
  passwordEnc String // AES-256-GCM encrypted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== AI provider credentials (OpenCode Zen / OpenAI-compatible) =====

model AiCredential {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeyEnc  String   // AES-256-GCM encrypted API key
  provider   String   @default("openai") // multi-llm-ts engine id (openai|deepseek|anthropic|openrouter|ollama|...)
  baseUrl    String?  // optional custom base URL (e.g. OpenCode Zen: https://opencode.ai/zen/v1)
  modelId    String?  // optional model id override
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ===== Athena Workspaces (saved window layouts) =====

model Workspace {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  layout    String   // JSON: array of { appId, title, rect, payload }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

// ===== AI Study Hub (activity log for study workflows) =====

model StudySession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "flashcards" | "summary" | "quiz" | "explain" | "study_guide" | "syllabus"
  title     String
  sourceRef String   @default("") // note id / file id / "paste"
  meta      String   @default("") // JSON: card count, score, etc.
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ===== Calendar / Planner =====

model CalendarEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  start       DateTime
  end         DateTime
  allDay      Boolean  @default(false)
  color       String   @default("#6366f1")
  location    String   @default("")
  source      String   @default("manual") // manual|task|vut|assignment|ics
  sourceRef   String   @default("")       // taskId / ics uid / etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, start])
}

// ===== Habit Tracker =====

model Habit {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  icon         String   @default("✅")
  color        String   @default("#6366f1")
  cadence      String   @default("daily") // daily|weekly
  target       Int      @default(1)
  linkedApp    String?  // pomodoro|flashcards|null
  linkedMetric String?  // focusSessions|focusMinutes|reviews
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  logs         HabitLog[]

  @@index([userId])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId    String
  date      String   // YYYY-MM-DD
  value     Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([userId, date])
}
